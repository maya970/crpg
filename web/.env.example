# testnet | mainnet (matches InterwovenKit preset)
VITE_NETWORK=testnet
# Auto-sign: one wallet approval, then many Move dungeon txs without repeated popups.
# All game txs use MsgExecute — explicit mode scopes the session to that message type.
# Docs: https://docs.initia.xyz/interwovenkit/features/autosign/configuration
# VITE_ENABLE_AUTOSIGN=explicit
# VITE_CHAIN_ID=initiation-2
# Or permissive preset:
# VITE_ENABLE_AUTOSIGN=true
# Initia REST root (no trailing slash)
VITE_LCD_URL=https://rest.testnet.initia.xyz
# Deployed Move module address for this game
VITE_MOVE_MODULE_ADDR=0x249A0913DB1FA0D5D8B425745B3277F61988A09F
# Gas price (match chain minimum)
VITE_GAS_PRICE=0.015uinit
# If the wallet reports "Failed to initialize request" on simulate, fee uses this gas (optional)
# VITE_FALLBACK_MSG_EXECUTE_GAS=3000000
