# testnet | mainnet — 与 InterwovenKit 预设一致
VITE_NETWORK=testnet
# Initia testnet REST（LCD）根地址，末尾不要斜杠 — initiation-2
VITE_LCD_URL=https://rest.testnet.initia.xyz
# Move 包发布地址：与 initiad move deploy 使用的 adventurer 地址一致（hex 或链上 REST 接受的 bech32）
VITE_MOVE_MODULE_ADDR=0x249A0913DB1FA0D5D8B425745B3277F61988A09F
# 与链上 minimum gas 对齐；部署时示例为 0.015uinit
VITE_GAS_PRICE=0.015uinit
